{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "crm-system-backup-cron",
  "main": "workers/backup-cron.ts",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "triggers": {
    "crons": ["0 21 * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "crm-db",
      "database_id": "03633dd2-c058-42de-9355-f5450eab7202"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS",
      "bucket_name": "crm-attachments",
      "preview_bucket_name": "crm-attachments-preview"
    }
  ]
}
